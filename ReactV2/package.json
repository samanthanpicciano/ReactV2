{
  "name": "ct-react-backend",
  "version": "2.0.0",
  "description": "CT React backend — auth, API proxy, shared Postgres state",
  "main": "server.js",
  "private": true,
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "dev:frontend": "cd ../ct-react-frontend && npm run dev"
  },
  "dependencies": {
    "cookie-parser":    "^1.4.6",
    "cors":             "^2.8.5",
    "dotenv":           "^16.4.5",
    "express":          "^4.19.2",
    "googleapis":       "^140.0.1",
    "jsonwebtoken":     "^9.0.2",
    "node-fetch":       "^3.3.2",
    "pg":               "^8.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon":      "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
